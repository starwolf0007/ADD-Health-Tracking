<?xml version="1.0" encoding="utf-8"?>
<!--
  NeuroFlow AndroidManifest.xml
  ─────────────────────────────
  This file MERGES with the one Flutter generates under android/app/src/main/.
  If you already have an AndroidManifest.xml in your repo (from `flutter create`),
  copy only the <uses-permission> blocks and the <receiver> / <service> tags into
  the right sections of your existing file. Don't overwrite the <activity> block
  that Flutter generated — it contains generated theme references.

  Permissions added vs. the default Flutter template:
    • POST_NOTIFICATIONS         — flutter_local_notifications (Android 13+)
    • RECEIVE_BOOT_COMPLETED     — WorkManager resumes jobs after reboot
    • FOREGROUND_SERVICE         — WorkManager long-running task support
    • WAKE_LOCK                  — keeps CPU awake while WorkManager runs
    • INTERNET                   — future Google Tasks sync (Phase 2)
    • ACCESS_NETWORK_STATE       — check connectivity before syncing
    • READ_* health permissions  — read-only Health Connect Phase 1.5 adapter
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ── Permissions ── -->

    <!-- Notifications (Android 13+ / API 33+ requires explicit permission) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- WorkManager: survive device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>

    <!-- WorkManager: run foreground services (long tasks, future sync) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>

    <!-- WorkManager: keep CPU awake while work completes -->
    <uses-permission android:name="android.permission.WAKE_LOCK"/>

    <!-- Network: future Google Tasks sync (Phase 2 — safe to include now) -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <!-- Health Connect: Phase 1.5 is intentionally read-only. -->
    <uses-permission android:name="android.permission.health.READ_STEPS"/>
    <uses-permission android:name="android.permission.health.READ_HEART_RATE"/>
    <uses-permission android:name="android.permission.health.READ_RESTING_HEART_RATE"/>
    <uses-permission android:name="android.permission.health.READ_SLEEP"/>
    <uses-permission android:name="android.permission.health.READ_EXERCISE"/>
    <uses-permission android:name="android.permission.health.READ_WEIGHT"/>

    <!-- Health Connect provider discovery for Android 13 and earlier. -->
    <queries>
        <package android:name="com.google.android.apps.healthdata"/>
    </queries>

    <!--
      NOTE: We intentionally do NOT request SCHEDULE_EXACT_ALARM.
      BackgroundScheduler uses AndroidScheduleMode.inexactAllowWhileIdle
      (flutter_local_notifications) which doesn't require exact alarm permission.
      If Phase 2 needs exact alarms, add USE_EXACT_ALARM (API 33+) and handle
      the ACTION_MANAGE_APP_USE_EXACT_ALARM settings redirect.
    -->

    <application
        android:label="NeuroFlow"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">

        <!-- Flutter entry point — keep this exactly as `flutter create` generated it -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme"/>
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Health Connect privacy/rationale surface for Android 13 and earlier. -->
        <activity
            android:name=".healthconnect.PermissionsRationaleActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE"/>
            </intent-filter>
        </activity>

        <!-- Health Connect privacy/rationale surface for Android 14 and later. -->
        <activity-alias
            android:name=".healthconnect.ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".healthconnect.PermissionsRationaleActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE"/>
                <category android:name="android.intent.category.HEALTH_PERMISSIONS"/>
            </intent-filter>
        </activity-alias>

        <!-- Flutter embedding version — required -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2"/>

        <!--
          WorkManager background callback dispatcher.
          The Dart entry point `callbackDispatcher` in background_scheduler.dart
          is registered via Workmanager().initialize() at runtime. WorkManager's
          own receiver is auto-merged from its AAR manifest, but the foreground
          service declaration below is ours to own.
        -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            android:exported="false"/>

        <!--
          flutter_local_notifications: BroadcastReceiver that fires scheduled
          notifications. Auto-merged from the plugin's AAR; listed here for
          visibility and so code-search finds the permission chain.
          (No action needed — the plugin registers this itself via manifest merge.)
        -->

    </application>

</manifest>
